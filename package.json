{
	"name": "lunar-ui",
	"version": "0.1.0",
	"description": "A Material 3-flavored Tailwind v4 plugin with optional Svelte 5 components.",
	"keywords": [
		"tailwindcss",
		"tailwindcss-v4",
		"material-design",
		"material-3",
		"svelte",
		"svelte5",
		"sveltekit",
		"ui",
		"components",
		"css-first"
	],
	"license": "MIT",
	"author": "Anti049",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Anti049/lunar-ui.git"
	},
	"homepage": "https://github.com/Anti049/lunar-ui#readme",
	"bugs": "https://github.com/Anti049/lunar-ui/issues",
	"files": [
		"dist",
		"THIRD_PARTY_NOTICES.md"
	],
	"sideEffects": [
		"**/*.css"
	],
	"exports": {
		".": "./dist/styles/index.css",
		"./reference": "./dist/styles/core/reference.css",
		"./themes": "./dist/styles/themes/index.css",
		"./themes/default": "./dist/styles/themes/default.css",
		"./themes/gaziter": "./dist/styles/themes/gaziter.css",
		"./themes/catppuccin": "./dist/styles/themes/catppuccin/index.css",
		"./themes/catppuccin/latte": "./dist/styles/themes/catppuccin/latte.css",
		"./themes/catppuccin/frappe": "./dist/styles/themes/catppuccin/frappe.css",
		"./themes/catppuccin/macchiato": "./dist/styles/themes/catppuccin/macchiato.css",
		"./themes/catppuccin/mocha": "./dist/styles/themes/catppuccin/mocha.css",
		"./components": "./dist/styles/components/index.css",
		"./svelte": {
			"types": "./dist/svelte/index.d.ts",
			"svelte": "./dist/svelte/index.js",
			"default": "./dist/svelte/index.js"
		},
		"./utils": {
			"types": "./dist/svelte/utils/index.d.ts",
			"default": "./dist/svelte/utils/index.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"dev": "vite dev",
		"build:css": "bun run scripts/build-css.ts",
		"build:svelte": "svelte-kit sync && svelte-package --input src/lib/svelte --output dist/svelte",
		"build": "bun run build:css && bun run build:svelte",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"generate:tokens": "bun run scripts/generate-tokens.ts",
		"validate": "publint && attw --pack .",
		"components:status": "bun run scripts/update-components-md.ts",
		"test:install:link": "bun run --cwd test-consumer install:link",
		"test:install:fresh": "bun run --cwd test-consumer install:fresh",
		"test:install:dev": "bun run --cwd test-consumer dev",
		"prepare": "bun run build",
		"prepublishOnly": "bun run build && bun run validate"
	},
	"peerDependencies": {
		"mode-watcher": "^1.1.0",
		"svelte": "^5.0.0",
		"tailwindcss": "^4.0.0"
	},
	"peerDependenciesMeta": {
		"mode-watcher": {
			"optional": true
		},
		"svelte": {
			"optional": true
		}
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@vitest/browser-playwright": "^4.1.8",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"mode-watcher": "^1.1.0",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"publint": "^0.3.21",
		"runed": "^0.37.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@fontsource-variable/fira-code": "^5.2.7",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/plus-jakarta-sans": "^5.2.8",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.6.0"
	}
}
